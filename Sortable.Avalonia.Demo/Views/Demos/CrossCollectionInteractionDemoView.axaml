<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.CrossCollectionInteractionDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:CrossCollectionInteractionDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:CrossCollectionInteractionDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Cross-Collection Transfer" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Drag incident cards between Intake and Resolution. Use the buttons for animated programmatic transfers."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Items can be dragged between collections instantly, or moved programmatically with animation via the buttons."
                Severity="Informational"
                Title="Tip" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Theme="{StaticResource AccentButtonTheme}" Command="{Binding MoveTopIntakeToResolutionCommand}" Content="Resolve Top Incident" />
                <Button Command="{Binding MoveTopResolutionToIntakeCommand}" Content="Re-open Top Resolution" />
                <Button Command="{Binding MoveRandomDirectionCommand}" Content="Random Transfer" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border
                    Grid.Column="0"
                    Padding="10"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ui:SymbolIcon Symbol="Mail" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock FontWeight="SemiBold" VerticalAlignment="Center" Text="Incident Intake" />
                        </StackPanel>
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="cross-animation"
                            sortable:Sortable.Sortable="True"
                            sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                            ItemsSource="{Binding Intake}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        sortable:Sortable.IsSortable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,9" Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}"
                                                        TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        FontSize="16"
                                                        Text="{Binding Tag}" />
                                                </Grid>
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="10"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ui:SymbolIcon Symbol="Checkmark" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock FontWeight="SemiBold" VerticalAlignment="Center" Text="Resolved" />
                        </StackPanel>
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="cross-animation"
                            sortable:Sortable.Sortable="True"
                            sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                            ItemsSource="{Binding Resolution}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        sortable:Sortable.IsSortable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,9" Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}"
                                                        TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        FontSize="16"
                                                        Text="{Binding Tag}" />
                                                </Grid>
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
